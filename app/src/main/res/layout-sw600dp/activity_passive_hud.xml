<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/show_bg"
    android:orientation="vertical"
    android:padding="14dp"
    tools:context=".PassiveHudActivity">

    <include
        layout="@layout/component_passive_readonly_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <include
        layout="@layout/component_status_bar"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginTop="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.2"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="5.5"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    layout="@layout/component_qlab_cue_pair_panel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <include
                    layout="@layout/component_ma2_cue_pair_panel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <include
                layout="@layout/component_memo_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="2.4" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1.4"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <include
                    layout="@layout/component_lighting_panel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="6dp"
                    android:layout_weight="1" />

                <include
                    layout="@layout/component_recovery_panel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:layout_weight="0.95"
            android:orientation="vertical">

            <include
                layout="@layout/component_sync_warning_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <include
                layout="@layout/component_risk_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1.15" />

            <include
                layout="@layout/component_watchdog_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1.1" />

            <include
                layout="@layout/component_checklist_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1.05" />

            <include
                layout="@layout/component_event_log_panel"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="10dp"
                android:layout_weight="1.1" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
