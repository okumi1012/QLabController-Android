<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/qlabCueCard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="@color/show_panel"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/show_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QLAB"
            android:textColor="@color/show_info"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CURRENT"
                android:textColor="@color/show_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/qlabCurrentNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/show_text"
                android:textSize="44sp"
                android:textStyle="bold"
                tools:text="12" />

            <TextView
                android:id="@+id/qlabCurrentNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/show_text"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Door knock SFX" />

            <TextView
                android:id="@+id/qlabCurrentMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_muted"
                android:textSize="13sp"
                tools:text="audio / running / 4.2s" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/show_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NEXT QLAB"
                android:textColor="@color/show_prepare"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/qlabNextNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/show_prepare"
                android:textSize="34sp"
                android:textStyle="bold"
                tools:text="13" />

            <TextView
                android:id="@+id/qlabNextNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/show_text"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Blackout transition" />

            <TextView
                android:id="@+id/qlabNextMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_muted"
                android:textSize="13sp"
                tools:text="group" />

            <TextView
                android:id="@+id/qlabNextRiskText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
