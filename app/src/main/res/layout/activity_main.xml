<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/show_bg"
    android:orientation="vertical"
    android:padding="18dp"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="QLab Controller"
        android:textColor="@color/show_text"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Remote first. HUD awareness is built into the controller."
        android:textColor="@color/show_muted"
        android:textSize="15sp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/connectionCard"
        style="@style/HomeActionCard"
        android:layout_marginTop="28dp"
        app:strokeColor="@color/show_info">

        <LinearLayout style="@style/HomeActionContent">
            <TextView
                style="@style/HomeActionBadge"
                android:text="CONN" />

            <LinearLayout style="@style/HomeActionTextBlock">
                <TextView
                    style="@style/HomeActionTitle"
                    android:text="Connection" />

                <TextView
                    style="@style/HomeActionSubtitle"
                    android:maxLines="2"
                    android:text="Find QLab automatically or enter IP manually. Opens the controller after connect." />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/settingsCard"
        style="@style/HomeActionCard">

        <LinearLayout style="@style/HomeActionContent">
            <TextView
                style="@style/HomeActionBadge"
                android:text="SET" />

            <LinearLayout style="@style/HomeActionTextBlock">
                <TextView
                    style="@style/HomeActionTitle"
                    android:text="Settings" />

                <TextView
                    style="@style/HomeActionSubtitle"
                    android:maxLines="2"
                    android:text="Configuration only." />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
