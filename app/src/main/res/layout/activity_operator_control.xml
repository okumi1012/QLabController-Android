<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/show_bg"
    android:orientation="vertical"
    android:padding="10dp"
    tools:context=".OperatorControlActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/showTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_text"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Winter Room" />

            <TextView
                android:id="@+id/sceneText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_muted"
                android:textSize="12sp"
                tools:text="Scene 3 / Solo operator" />
        </LinearLayout>

        <TextView
            android:id="@+id/showClockText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:textColor="@color/show_info"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="19:42:20" />
    </LinearLayout>

    <include
        layout="@layout/component_compact_status_chips"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="1.9"
        android:orientation="vertical">

        <include
            layout="@layout/component_qlab_cue_pair_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <include
            layout="@layout/component_ma2_cue_pair_panel"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1" />
    </LinearLayout>

    <include
        layout="@layout/component_memo_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="0.65" />

    <include
        layout="@layout/component_operator_controls"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_weight="0.85" />
</LinearLayout>
