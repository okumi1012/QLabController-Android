<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ma2CueCard"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:cardBackgroundColor="@color/show_panel"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/show_border"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="grandMA2"
            android:textColor="@color/show_info"
            android:textSize="13sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CURRENT"
                android:textColor="@color/show_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ma2CurrentNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/show_text"
                android:textSize="54sp"
                android:textStyle="bold"
                tools:text="23" />

            <TextView
                android:id="@+id/ma2CurrentNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/show_text"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Interior warm wash" />

            <TextView
                android:id="@+id/ma2CurrentMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_muted"
                android:textSize="15sp"
                tools:text="Main sequence" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:background="@color/show_border" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NEXT MA2"
                android:textColor="@color/show_prepare"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/ma2NextNumberText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/show_prepare"
                android:textSize="44sp"
                android:textStyle="bold"
                tools:text="24" />

            <TextView
                android:id="@+id/ma2NextNameText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/show_text"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Snap blackout" />

            <TextView
                android:id="@+id/ma2NextMetaText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/show_muted"
                android:textSize="15sp"
                tools:text="Main sequence" />

            <TextView
                android:id="@+id/ma2NextRiskText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/expectedLightingText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/show_muted"
                android:textSize="13sp"
                tools:text="Expected: MA2 Cue 24 / Snap blackout" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
